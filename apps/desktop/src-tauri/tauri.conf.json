{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SmartSistema",
  "version": "0.1.0",
  "identifier": "online.smartsystema.agent",
  "mainBinaryName": "SmartSistema",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SmartSistema",
        "width": 1080,
        "height": 760,
        "minWidth": 800,
        "minHeight": 560
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* https://*:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "publisher": "SmartSistema",
    "shortDescription": "AI document recognition agent for 1C draft creation.",
    "longDescription": "SmartSistema recognizes primary accounting documents and safely prepares reviewable drafts for 1C.",
    "category": "Business",
    "targets": "all",
    "windows": {
      "allowDowngrades": false,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "languages": ["Russian", "English"],
        "displayLanguageSelector": true,
        "startMenuFolder": "SmartSistema"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
