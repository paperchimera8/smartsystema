{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "СмартСистема Agent",
  "version": "0.1.0",
  "identifier": "com.automator.agent",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "СмартСистема Agent",
        "width": 1080,
        "height": 760,
        "minWidth": 800,
        "minHeight": 560
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* https://*:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
