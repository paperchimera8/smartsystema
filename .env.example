NODE_ENV=development
PORT=8080
API_CORS_ORIGINS=http://127.0.0.1:1420,http://localhost:1420
API_SWAGGER_ENABLED=true
API_ALLOW_PRIVATE_NETWORK_CORS=true

DATABASE_URL=postgres://automator:automator@localhost:5434/automator
REDIS_URL=redis://localhost:6379
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=automator
OBJECT_STORAGE_SECRET_KEY=automator-secret
OBJECT_STORAGE_BUCKET=automator-documents

OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
AUTH_JWT_SECRET=automator-local-development-jwt-secret-change-me
AUTH_DEFAULT_TENANT_ID=tenant-local
AUTH_NATIVE_RETURN_URL=automator://auth-complete

OPENAI_API_KEY=
OPENAI_OCR_MODEL=gpt-4o-mini

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILE_SESSION_SAMPLE_RATE=1.0
SENTRY_PROFILE_LIFECYCLE=trace
SENTRY_ENABLE_LOGS=true

VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
